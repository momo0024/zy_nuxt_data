{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./*"],
      "@/*": ["./*"]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "./**/*",
    ".nuxt/nuxt.d.ts",
    ".nuxt/types/**/*.d.ts",
    ".nuxt/imports.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".output"
  ]
}